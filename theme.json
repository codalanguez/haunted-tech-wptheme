{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "background": true,
      "customDuotone": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "name": "Void",        "slug": "void",        "color": "#000000" },
        { "name": "Onyx",        "slug": "onyx",        "color": "#050403" },
        { "name": "Obsidian",    "slug": "obsidian",    "color": "#0F0D0A" },
        { "name": "Panel",       "slug": "panel",       "color": "#14110C" },
        { "name": "Gold",        "slug": "gold",        "color": "#FFD400" },
        { "name": "Gold Bright", "slug": "gold-bright", "color": "#FFE875" },
        { "name": "Gold Deep",   "slug": "gold-deep",   "color": "#B89200" },
        { "name": "Red",         "slug": "red",         "color": "#E50914" },
        { "name": "Red Bright",  "slug": "red-bright",  "color": "#FF1F2E" },
        { "name": "Red Deep",    "slug": "red-deep",    "color": "#5A0A12" },
        { "name": "Teal",        "slug": "teal",        "color": "#1A4550" },
        { "name": "Cyan",        "slug": "cyan",        "color": "#00FFE0" },
        { "name": "Bone",        "slug": "bone",        "color": "#F5EFD8" },
        { "name": "Bone Dim",    "slug": "bone-dim",    "color": "#8C8775" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Forum, serif",
          "name": "Forum",
          "slug": "forum",
          "fontFace": [{ "fontFamily": "Forum", "fontWeight": "400", "fontStyle": "normal", "src": ["https://fonts.gstatic.com/s/forum/v18/6aey4Ky-Vb8Ew_IWMJMa3mnT.woff2"] }]
        },
        {
          "fontFamily": "Inter, sans-serif",
          "name": "Inter",
          "slug": "inter"
        },
        {
          "fontFamily": "'Cormorant Garamond', serif",
          "name": "Cormorant Garamond",
          "slug": "cormorant"
        },
        {
          "fontFamily": "VT323, monospace",
          "name": "VT323",
          "slug": "vt323"
        }
      ],
      "fontSizes": [
        { "name": "Small",    "slug": "small",    "size": "0.85rem" },
        { "name": "Body",     "slug": "body",     "size": "1rem" },
        { "name": "Large",    "slug": "large",    "size": "1.2rem" },
        { "name": "Heading",  "slug": "heading",  "size": "1.6rem" },
        { "name": "Display",  "slug": "display",  "size": "2.4rem" },
        { "name": "Hero",     "slug": "hero",     "size": "clamp(3rem, 9vw, 7rem)" }
      ],
      "dropCap":      false,
      "letterSpacing": true,
      "textTransform": true,
      "fontStyle":    true
    },
    "spacing": {
      "padding":  true,
      "margin":   true,
      "blockGap": true,
      "units":    ["px", "em", "rem", "%", "vh", "vw"]
    },
    "layout": {
      "contentSize": "1100px",
      "wideSize":    "1300px"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--void)",
      "text":       "var(--wp--preset--color--bone)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color":  { "text": "var(--wp--preset--color--gold)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--red)" } }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--forum)", "textTransform": "uppercase" }, "color": { "text": "var(--wp--preset--color--gold)" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--forum)", "textTransform": "uppercase" }, "color": { "text": "var(--wp--preset--color--gold)" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--forum)", "textTransform": "uppercase" }, "color": { "text": "var(--wp--preset--color--gold)" } }
    }
  },
  "customTemplates": [
    { "name": "single-book",     "title": "Single Book Layout",      "postTypes": ["book"] },
    { "name": "single-webnovel", "title": "Single Web Novel Layout", "postTypes": ["webnovel"] },
    { "name": "single-chapter",  "title": "Single Chapter Layout",   "postTypes": ["chapter"] },
    { "name": "archive-book",    "title": "Bookshelf Archive",       "postTypes": ["page"] },
    { "name": "archive-webnovel","title": "Web Novels Archive",      "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
